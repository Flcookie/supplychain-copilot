{
  "on_time_rate": {
    "business_name": "On-Time Delivery Rate",
    "definition": "On-time deliveries / total deliveries (delivery_events.on_time_flag = 1)",
    "formula": "AVG(on_time_flag) * 100 or vendor_rating.on_time_delivery_rate_pct",
    "default_time_window": "2025",
    "required_tables": ["suppliers", "delivery_events", "vendor_rating"],
    "fields": ["supplier_id", "on_time_flag", "actual_delivery_date"],
    "dimensions": ["supplier", "category_level_2", "country"],
    "minimum_sample_size": 5,
    "data_snapshot": "demo SQLite ratti_copilot_demo.db"
  },
  "defect_rate": {
    "business_name": "Quality Defect Rate",
    "definition": "Average defect rate from quality_events or vendor_rating.quality_defect_rate_pct",
    "formula": "AVG(quality_events.defect_rate) * 100",
    "default_time_window": "2025",
    "required_tables": ["suppliers", "quality_events", "vendor_rating"],
    "fields": ["supplier_id", "defect_rate", "severity"],
    "dimensions": ["supplier", "category_level_2"],
    "minimum_sample_size": 3,
    "data_snapshot": "demo SQLite ratti_copilot_demo.db"
  },
  "avg_delay_days": {
    "business_name": "Average Delivery Delay Days",
    "definition": "Average delivery_delay_days from delivery_events",
    "formula": "AVG(delivery_delay_days)",
    "default_time_window": "2025",
    "required_tables": ["suppliers", "delivery_events"],
    "fields": ["supplier_id", "delivery_delay_days"],
    "dimensions": ["supplier", "category_level_2", "risk_level"],
    "minimum_sample_size": 3,
    "data_snapshot": "demo SQLite ratti_copilot_demo.db"
  },
  "vendor_rating": {
    "business_name": "Vendor Rating Score",
    "definition": "Weighted score combining operational, risk inverse and ESG dimensions",
    "formula": "operational_score * w_op + risk_inverse_score * w_risk + esg_score * w_esg",
    "default_time_window": "2025",
    "required_tables": ["vendor_rating", "suppliers", "category_rules"],
    "fields": ["final_vendor_rating_score", "rating_class", "suggested_action"],
    "dimensions": ["supplier", "kraljic_quadrant", "category_level_2"],
    "minimum_sample_size": 1,
    "data_snapshot": "demo SQLite ratti_copilot_demo.db"
  },
  "esg_score": {
    "business_name": "ESG Score",
    "definition": "Weighted E/S/G score: E*0.4 + S*0.3 + G*0.3",
    "formula": "environmental_score_0_100 * 0.4 + social_score_0_100 * 0.3 + governance_score_0_100 * 0.3",
    "default_time_window": "latest_assessment",
    "required_tables": ["esg_assessments", "suppliers", "documents"],
    "fields": ["final_esg_score", "missing_or_expired_documents"],
    "dimensions": ["supplier"],
    "minimum_sample_size": 1,
    "data_snapshot": "demo SQLite ratti_copilot_demo.db"
  },
  "spend": {
    "business_name": "Annual Spend",
    "definition": "Synthetic supplier-level annual spend in EUR",
    "formula": "SUM(annual_spend_eur) GROUP BY kraljic_quadrant",
    "default_time_window": "current_year",
    "required_tables": ["suppliers"],
    "fields": ["annual_spend_eur", "kraljic_quadrant"],
    "dimensions": ["kraljic_quadrant", "category_level_2"],
    "minimum_sample_size": 1,
    "data_snapshot": "demo SQLite ratti_copilot_demo.db (synthetic spend)"
  }
}
